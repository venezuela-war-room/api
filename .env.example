DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/terremoto
MASTER_ADMIN_KEY=change-me-to-a-long-random-secret
CORS_ORIGINS=["*"]
DEBUG=false


# ── Geocoding (OpenStreetMap Nominatim) — all optional, sensible defaults ──────
# A background worker fills facility addresses (direccion/lat/lon) asynchronously.
# GEOCODING_ENABLED=true
# GEOCODING_WORKER_ENABLED=true
# GEOCODING_WORKER_INTERVAL=60
# GEOCODING_BATCH_SIZE=10
# NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
# NOMINATIM_USER_AGENT=your-app/1.0 (+https://your-contact)
# GEOCODING_TIMEOUT=5.0
# Public Nominatim forbids parallel requests — keep concurrency at 1 and delay >= 1s
# unless NOMINATIM_BASE_URL points at a self-hosted/commercial instance.
# GEOCODING_CONCURRENCY=1
# GEOCODING_REQUEST_DELAY=1.0
# GEOCODING_COUNTRY_CODES=ve


ENVIRONMENT=development
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

